{
  "name": "openaver-lint",
  "version": "0.0.1",
  "private": true,
  "description": "ESLint + stylelint devtools for OpenAver frontend",
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "lint:js": "eslint web/static/js/",
    "lint:css": "stylelint \"web/static/css/**/*.css\"",
    "lint:html": "node scripts/lint-settings-ia.mjs",
    "test:tokenizer": "node --test \"web/static/js/pages/settings/__tests__/**/*.test.mjs\""
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/cli": "^4.1.18",
    "daisyui": "^5.5.17",
    "eslint": "^9.39.4",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0",
    "tailwindcss": "^4.1.18"
  }
}
